<script>
// Helper functions
function showMsg(id, text, success = true) {
    const el = document.getElementById(id);
    el.textContent = text;
    el.className = (success ? 'success-msg' : 'err-msg') + ' show';
    setTimeout(() => el.classList.remove('show'), 4000);
}

function gradeNames(g) { return {'10':'الصف العاشر','11':'الصف الحادي عشر','12':'الصف الثاني عشر'}[String(g)] || g; }

// Auto-calculate grade from score
function autoGrade() {
    const score = parseInt(document.getElementById('marks-score').value);
    const sel = document.getElementById('marks-grade');
    if (isNaN(score)) return;
    if (score >= 90) sel.value = 'A';
    else if (score >= 80) sel.value = 'B';
    else if (score >= 70) sel.value = 'C';
    else if (score >= 60) sel.value = 'D';
    else sel.value = 'F';
}

// Clock
function updateClock() {
    const now = new Date();
    document.getElementById('header-time').textContent = now.toLocaleTimeString('ar-SA');
}
setInterval(updateClock, 1000);

// ====== LOGIN / LOGOUT ======
async function doAdminLogin() {
    const username = document.getElementById('admin-username').value.trim();
    const password = document.getElementById('admin-password').value.trim();
    const btn = document.getElementById('loginBtn');
    const errorEl = document.getElementById('login-error');
    errorEl.classList.remove('show');
    if (!username || !password) { errorEl.textContent = 'يرجى إدخال اسم المستخدم وكلمة المرور'; errorEl.classList.add('show'); return; }
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحقق...';
    try {
        const res = await fetch('/api/admin-login', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({username, password}) });
        const data = await res.json();
        if (data.success) {
            document.getElementById('loginBox').style.display = 'none';
            document.getElementById('adminDashboard').classList.add('active');
            document.body.style.overflow = '';
            loadDashboardStats();
            loadAllStudents();
        } else {
            errorEl.textContent = data.error || 'بيانات غير صحيحة';
            errorEl.classList.add('show');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> دخول لوحة الإدارة';
        }
    } catch(err) {
        errorEl.textContent = 'خطأ في الاتصال. حاول مرة أخرى.';
        errorEl.classList.add('show');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> دخول لوحة الإدارة';
    }
}

function doLogout() {
    document.getElementById('adminDashboard').classList.remove('active');
    document.getElementById('loginBox').style.display = 'block';
    document.getElementById('admin-username').value = '';
    document.getElementById('admin-password').value = '';
}

// ====== TABS ======
function switchTab(tab, btn) {
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.admin-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
}

// ====== DASHBOARD STATS ======
async function loadDashboardStats() {
    try {
        const res = await fetch('/api/get-all-students');
        const data = await res.json();
        if (data.success) {
            const students = data.students;
            document.getElementById('stat-students').textContent = students.length;
            document.getElementById('count-10').textContent = students.filter(s => String(s.grade_level) === '10').length;
            document.getElementById('count-11').textContent = students.filter(s => String(s.grade_level) === '11').length;
            document.getElementById('count-12').textContent = students.filter(s => String(s.grade_level) === '12').length;
        }
    } catch(e) { console.error(e); }
    try {
        const res = await fetch('/api/get-all-results');
        const data = await res.json();
        if (data.success) {
            document.getElementById('stat-results').textContent = data.results.length;
        }
    } catch(e) { console.error(e); }
    document.getElementById('stat-subjects').textContent = '18';
}

// ====== STUDENT FUNCTIONS ======
let cachedStudents = [];
async function filterStudentsByGradeClass() {
    const grade = document.getElementById('marks-grade-filter').value;
    const cls = document.getElementById('marks-class-filter').value;
    const select = document.getElementById('marks-studentId');
    if (!grade || !cls) { select.innerHTML = '<option value="">-- اختر الصف والفصل أولاً --</option>'; return; }
    select.innerHTML = '<option value="">جاري التحميل...</option>';
    try {
        if (!cachedStudents.length) {
            const res = await fetch('/api/get-all-students');
            const data = await res.json();
            cachedStudents = data.success ? data.students : [];
        }
        const filtered = cachedStudents.filter(s => String(s.grade_level) === grade && s.class_name === cls);
        select.innerHTML = filtered.length ? '<option value="">-- اختر الطالب --</option>' + filtered.map(s => `<option value="${s.student_id}">${s.student_id} - ${s.full_name}</option>`).join('') : '<option value="">لا يوجد طلاب في هذا الفصل</option>';
    } catch { select.innerHTML = '<option value="">خطأ في التحميل</option>'; }
}

async function saveMarks() {
    const studentId = document.getElementById('marks-studentId').value;
    const subject = document.getElementById('marks-subject').value;
    const score = parseInt(document.getElementById('marks-score').value);
    const grade = document.getElementById('marks-grade').value;
    const academicYear = document.getElementById('marks-year').value.trim();
    const term = document.getElementById('marks-term').value;
    const successEl = document.getElementById('marks-success'), errorEl = document.getElementById('marks-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId || !subject || isNaN(score) || !grade || !academicYear || !term) { errorEl.textContent = 'يرجى ملء جميع الحقول'; errorEl.classList.add('show'); return; }
    try {
        const res = await fetch('/api/add-marks', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({studentId, subject, score, grade, academicYear, term})});
        const data = await res.json();
        if (data.success) { showMsg('marks-success', '✅ تم حفظ النتيجة بنجاح!'); document.getElementById('marks-score').value = ''; }
        else { showMsg('marks-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('marks-error', 'خطأ في الاتصال', false); }
}

async function saveStudent() {
    const studentId = document.getElementById('new-studentId').value.trim();
    const fullName = document.getElementById('new-fullName').value.trim();
    const password = document.getElementById('new-password').value.trim();
    const gradeLevel = document.getElementById('new-gradeLevel').value;
    const className = document.getElementById('new-className').value;
    const successEl = document.getElementById('student-success'), errorEl = document.getElementById('student-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId || !fullName || !password) { errorEl.textContent = 'يرجى ملء جميع الحقول المطلوبة'; errorEl.classList.add('show'); return; }
    try {
        const res = await fetch('/api/add-student', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({studentId, fullName, password, gradeLevel: parseInt(gradeLevel), className})});
        const data = await res.json();
        if (data.success) {
            showMsg('student-success', `✅ تم إضافة الطالب ${fullName} بنجاح!`);
            document.getElementById('new-studentId').value = '';
            document.getElementById('new-fullName').value = '';
            document.getElementById('new-password').value = '';
            cachedStudents = [];
            loadAllStudents();
            loadDashboardStats();
        } else { showMsg('student-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('student-error', 'خطأ في الاتصال', false); }
}

let allStudentsData = [];
async function loadAllStudents() {
    const tbody = document.getElementById('allStudentsBody');
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;"><i class="fas fa-spinner fa-spin"></i> جاري التحميل...</td></tr>';
    try {
        const res = await fetch('/api/get-all-students');
        const data = await res.json();
        if (data.success) {
            allStudentsData = data.students;
            document.getElementById('students-count').innerHTML = '<i class="fas fa-users"></i> الطلاب: ' + data.students.length;
            renderStudentsTable(data.students);
        } else { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;color:#c0392b;">فشل تحميل البيانات</td></tr>'; }
    } catch { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;color:#c0392b;">خطأ في الاتصال</td></tr>'; }
}

function renderStudentsTable(students) {
    const tbody = document.getElementById('allStudentsBody');
    if (!students.length) { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;color:#999;">لا يوجد طلاب</td></tr>'; return; }
    tbody.innerHTML = students.map((s,i) => `<tr><td>${i+1}</td><td style="font-weight:700;color:var(--green);">${s.student_id}</td><td>${s.full_name}</td><td>${gradeNames(String(s.grade_level))}</td><td>${s.class_name||'-'}</td></tr>`).join('');
}

function filterStudentsTable() {
    const q = document.getElementById('students-search').value.toLowerCase();
    const grade = document.getElementById('as-grade-filter').value;
    const cls = document.getElementById('as-class-filter').value;
    let filtered = allStudentsData;
    if (grade) filtered = filtered.filter(s => String(s.grade_level) === grade);
    if (cls) filtered = filtered.filter(s => s.class_name === cls);
    if (q) filtered = filtered.filter(s => s.student_id.toLowerCase().includes(q) || s.full_name.toLowerCase().includes(q));
    document.getElementById('students-count').innerHTML = '<i class="fas fa-users"></i> الطلاب: ' + filtered.length;
    renderStudentsTable(filtered);
}

async function updateStudent() {
    const studentId = document.getElementById('update-studentId').value.trim();
    const fullName = document.getElementById('update-fullName').value.trim() || undefined;
    const gradeLevel = document.getElementById('update-gradeLevel').value || undefined;
    const className = document.getElementById('update-className').value || undefined;
    const successEl = document.getElementById('update-success'), errorEl = document.getElementById('update-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId) { errorEl.textContent = 'يرجى إدخال رقم الطالب'; errorEl.classList.add('show'); return; }
    if (!fullName && !gradeLevel && !className) { errorEl.textContent = 'يرجى تعديل حقل واحد على الأقل'; errorEl.classList.add('show'); return; }
    try {
        const body = {studentId};
        if (fullName) body.fullName = fullName;
        if (gradeLevel) body.gradeLevel = parseInt(gradeLevel);
        if (className) body.className = className;
        const res = await fetch('/api/update-student', {method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)});
        const data = await res.json();
        if (data.success) {
            showMsg('update-success', '✅ تم تحديث بيانات الطالب بنجاح!');
            document.getElementById('update-studentId').value = '';
            document.getElementById('update-fullName').value = '';
            document.getElementById('update-gradeLevel').value = '';
            document.getElementById('update-className').value = '';
            cachedStudents = [];
            loadAllStudents();
        } else { showMsg('update-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('update-error', 'خطأ في الاتصال', false); }
}

async function deleteStudent() {
    const studentId = document.getElementById('delete-studentId').value.trim();
    const successEl = document.getElementById('delete-student-success'), errorEl = document.getElementById('delete-student-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId) { errorEl.textContent = 'يرجى إدخال رقم الطالب'; errorEl.classList.add('show'); return; }
    if (!confirm(`هل أنت متأكد من حذف الطالب ${studentId} وجميع نتائجه؟ لا يمكن التراجع!`)) return;
    try {
        const res = await fetch('/api/delete-student', {method:'DELETE', headers:{'Content-Type':'application/json'}, body: JSON.stringify({studentId})});
        const data = await res.json();
        if (data.success) {
            showMsg('delete-student-success', `✅ تم حذف الطالب ${studentId} بنجاح!`);
            document.getElementById('delete-studentId').value = '';
            cachedStudents = [];
            loadAllStudents();
            loadDashboardStats();
        } else { showMsg('delete-student-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('delete-student-error', 'خطأ في الاتصال', false); }
}

let allResultsData = [];
async function loadAllResults() {
    const tbody = document.getElementById('allResultsBody');
    const grade = document.getElementById('filter-grade').value;
    const cls = document.getElementById('filter-class').value;
    const year = document.getElementById('filter-year').value.trim();
    const term = document.getElementById('filter-term').value;
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:2rem;"><i class="fas fa-spinner fa-spin"></i> جاري التحميل...</td></tr>';
    const params = [];
    if (grade) params.push('gradeLevel=' + encodeURIComponent(grade));
    if (cls) params.push('className=' + encodeURIComponent(cls));
    if (year) params.push('academicYear=' + encodeURIComponent(year));
    if (term) params.push('term=' + encodeURIComponent(term));
    const url = '/api/get-all-results' + (params.length ? '?' + params.join('&') : '');
    try {
        const res = await fetch(url);
        const data = await res.json();
        if (data.success) {
            allResultsData = data.results;
            document.getElementById('results-count').innerHTML = '<i class="fas fa-list"></i> النتائج: ' + data.results.length;
            renderResultsTable(data.results);
        } else { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:2rem;color:#c0392b;">فشل تحميل البيانات</td></tr>'; }
    } catch { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:2rem;color:#c0392b;">خطأ في الاتصال</td></tr>'; }
}

function renderResultsTable(results) {
    const tbody = document.getElementById('allResultsBody');
    if (!results.length) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:2rem;color:#999;">لا توجد نتائج</td></tr>'; return; }
    const gradeShort = {'10':'العاشر','11':'الحادي عشر','12':'الثاني عشر'};
    tbody.innerHTML = results.map((r,i) => `<tr><td>${i+1}</td><td style="font-weight:700;color:var(--green);">${r.student_id}</td><td>${r.full_name}</td><td>${gradeShort[String(r.grade_level)]||'-'}</td><td>${r.class_name||'-'}</td><td>${r.subject}</td><td style="font-weight:700;">${r.score??'-'}</td><td><span class="grade-pill grade-${r.grade||'F'}">${r.grade||'-'}</span></td><td>${r.term||'-'}</td><td>${r.academic_year||'-'}</td></tr>`).join('');
}

function filterResultsTable() {
    const q = document.getElementById('results-search').value.toLowerCase();
    renderResultsTable(allResultsData.filter(r => r.student_id?.toLowerCase().includes(q) || r.full_name?.toLowerCase().includes(q) || r.subject?.toLowerCase().includes(q)));
}

async function deleteResults() {
    const studentId = document.getElementById('del-res-studentId').value.trim();
    const subject = document.getElementById('del-res-subject').value;
    const academicYear = document.getElementById('del-res-year').value.trim();
    const term = document.getElementById('del-res-term').value;
    const successEl = document.getElementById('del-res-success'), errorEl = document.getElementById('del-res-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId) { errorEl.textContent = 'يرجى إدخال رقم الطالب'; errorEl.classList.add('show'); return; }
    if (subject && (!academicYear || !term)) { errorEl.textContent = 'يرجى تحديد العام والفصل عند اختيار مادة معينة'; errorEl.classList.add('show'); return; }
    if (!confirm(subject ? `هل تريد حذف نتيجة ${subject} للطالب ${studentId}؟` : `هل تريد حذف جميع نتائج الطالب ${studentId}؟`)) return;
    try {
        const body = {studentId};
        if (subject) { body.subject = subject; body.academicYear = academicYear; body.term = term; }
        const res = await fetch('/api/delete-results', {method:'DELETE', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)});
        const data = await res.json();
        if (data.success) { showMsg('del-res-success', '✅ تم حذف النتائج بنجاح!'); document.getElementById('del-res-studentId').value = ''; }
        else { showMsg('del-res-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('del-res-error', 'خطأ في الاتصال', false); }
}

async function resetPassword() {
    const studentId = document.getElementById('reset-studentId').value.trim();
    const newPassword = document.getElementById('reset-newPassword').value.trim();
    const successEl = document.getElementById('reset-success'), errorEl = document.getElementById('reset-error');
    successEl.classList.remove('show'); errorEl.classList.remove('show');
    if (!studentId || !newPassword) { errorEl.textContent = 'يرجى إدخال رقم الطالب وكلمة المرور الجديدة'; errorEl.classList.add('show'); return; }
    try {
        const res = await fetch('/api/reset-password', {method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({studentId, newPassword})});
        const data = await res.json();
        if (data.success) { showMsg('reset-success', `✅ تم تعيين كلمة مرور جديدة للطالب ${studentId}!`); document.getElementById('reset-studentId').value = ''; document.getElementById('reset-newPassword').value = ''; }
        else { showMsg('reset-error', data.error || 'حدث خطأ', false); }
    } catch { showMsg('reset-error', 'خطأ في الاتصال', false); }
}

document.getElementById('admin-password').addEventListener('keypress', e => { if (e.key === 'Enter') doAdminLogin(); });
