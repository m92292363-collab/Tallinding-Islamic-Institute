<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بوابة الإدارة - معهد بتلند كنجا الإسلامي</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <meta name="robots" content="noindex, nofollow">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --green: #1e5a3a;
            --green-light: #2b7a4f;
            --green-pale: #e8f5ee;
            --accent: #FFB347;
            --accent-dark: #e09020;
            --bg: #f0f7f4;
            --red: #c0392b;
            --red-light: #e74c3c;
            --blue: #2471a3;
            --purple: #7d3c98;
            --card-shadow: 0 4px 20px rgba(30,90,58,0.08);
        }
        body {
            background: var(--bg);
            min-height: 100vh;
            font-family: 'Tajawal', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 20%, rgba(30,90,58,0.12) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255,179,71,0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        /* ====== LOGIN ====== */
        .login-box {
            background: white;
            border-radius: 2rem;
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 60px rgba(30,90,58,0.15);
            border: 1px solid rgba(30,90,58,0.1);
            position: relative;
            z-index: 1;
        }
        .login-box::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 5px;
            background: linear-gradient(90deg, var(--green), var(--accent), var(--green));
            border-radius: 2rem 2rem 0 0;
        }
        .logo {
            width: 80px; height: 80px;
            background: linear-gradient(135deg, var(--green), var(--green-light));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.5rem;
            border: 4px solid var(--accent);
            box-shadow: 0 8px 25px rgba(30,90,58,0.3);
        }
        .logo i { font-size: 2.2rem; color: var(--accent); }
        h1 { text-align: center; color: var(--green); font-size: 1.6rem; font-weight: 800; margin-bottom: 0.4rem; }
        .subtitle { text-align: center; color: #888; font-size: 0.9rem; margin-bottom: 2rem; }
        .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.2rem; }
        .form-group label { font-size: 0.85rem; font-weight: 600; color: #444; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 0.9rem; }
        .input-wrap input { width: 100%; padding: 0.85rem 2.8rem 0.85rem 1rem; border: 1.5px solid #e0e0e0; border-radius: 12px; font-size: 1rem; outline: none; transition: all 0.2s; background: #fafafa; text-align: right; font-family: 'Tajawal', sans-serif; }
        .input-wrap input:focus { border-color: var(--accent); background: white; box-shadow: 0 0 0 3px rgba(255,179,71,0.15); }
        .btn-login { width: 100%; padding: 1rem; background: linear-gradient(135deg, var(--green), var(--green-light)); color: white; border: none; border-radius: 12px; font-size: 1.05rem; font-weight: 700; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.6rem; margin-top: 0.5rem; font-family: 'Tajawal', sans-serif; }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(30,90,58,0.3); }
        .btn-login:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
        .error-msg { background: #fff5f5; color: #c0392b; padding: 0.8rem 1rem; border-radius: 10px; font-size: 0.9rem; margin-top: 1rem; display: none; text-align: center; }
        .error-msg.show { display: block; }
        .back-link { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 1.5rem; color: #aaa; font-size: 0.85rem; text-decoration: none; transition: color 0.2s; }
        .back-link:hover { color: var(--green); }

        /* ====== DASHBOARD ====== */
        .dashboard-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #f4f7f5; z-index: 9999; overflow-y: auto; direction: rtl; }
        .dashboard-overlay.active { display: block; }
        .dashboard-header { background: linear-gradient(135deg, #1e5a3a, #2b7a4f); color: white; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; box-shadow: 0 2px 15px rgba(0,0,0,0.25); }
        .dashboard-header h2 { font-size: 1.2rem; font-weight: 800; display: flex; align-items: center; gap: 0.5rem; }
        .dashboard-header h2 i { color: #FFB347; }
        .header-actions { display: flex; align-items: center; gap: 0.8rem; }
        .dashboard-logout { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 0.5rem 1.2rem; border-radius: 30px; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s; font-family: 'Tajawal', sans-serif; }
        .dashboard-logout:hover { background: rgba(255,255,255,0.25); }
        .dashboard-body { padding: 1.5rem; max-width: 1200px; margin: 0 auto; }

        /* ====== STATS GRID ====== */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
        .stat-card { background: white; border-radius: 1.2rem; padding: 1.2rem 1.5rem; box-shadow: var(--card-shadow); display: flex; align-items: center; gap: 1rem; border: 1px solid rgba(30,90,58,0.08); transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-3px); }
        .stat-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
        .stat-icon.green { background: linear-gradient(135deg, #1e5a3a, #2b7a4f); color: #FFB347; }
        .stat-icon.orange { background: linear-gradient(135deg, #e67e22, #f39c12); color: white; }
        .stat-icon.blue { background: linear-gradient(135deg, #2471a3, #3498db); color: white; }
        .stat-icon.purple { background: linear-gradient(135deg, #7d3c98, #9b59b6); color: white; }
        .stat-info { flex: 1; }
        .stat-number { font-size: 1.8rem; font-weight: 900; color: #1a1a1a; line-height: 1; }
        .stat-label { font-size: 0.8rem; color: #888; margin-top: 0.2rem; font-weight: 500; }

        /* ====== TABS ====== */
        .tabs-container { background: white; border-radius: 1.2rem; padding: 0.8rem; margin-bottom: 1.5rem; box-shadow: var(--card-shadow); display: flex; gap: 0.4rem; flex-wrap: wrap; }
        .admin-tab { padding: 0.6rem 1rem; border-radius: 10px; border: none; color: #666; background: transparent; cursor: pointer; font-weight: 600; font-size: 0.85rem; transition: all 0.2s; display: flex; align-items: center; gap: 0.4rem; font-family: 'Tajawal', sans-serif; white-space: nowrap; }
        .admin-tab:hover { background: var(--green-pale); color: var(--green); }
        .admin-tab.active { background: linear-gradient(135deg, var(--green), var(--green-light)); color: white; box-shadow: 0 4px 12px rgba(30,90,58,0.3); }
        .admin-tab i { font-size: 0.8rem; }
        .admin-panel { display: none; }
        .admin-panel.active { display: block; }

        /* ====== CARDS ====== */
        .admin-form-card { background: white; border-radius: 1.5rem; padding: 1.5rem; box-shadow: var(--card-shadow); margin-bottom: 1.5rem; border: 1px solid rgba(30,90,58,0.06); }
        .admin-form-card h3 { color: var(--green); font-size: 1.15rem; font-weight: 800; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.5rem; padding-bottom: 0.8rem; border-bottom: 2px solid var(--green-pale); }
        .admin-form-card h3 i { color: var(--accent); background: var(--green-pale); padding: 0.4rem; border-radius: 8px; }

        /* ====== FORM GRID ====== */
        .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
        .fg { display: flex; flex-direction: column; gap: 0.4rem; }
        .fg label { font-size: 0.82rem; font-weight: 700; color: #444; }
        .fg input, .fg select, .fg textarea {
            padding: 0.7rem 1rem; border: 1.5px solid #e8e8e8; border-radius: 10px; font-size: 0.95rem;
            outline: none; transition: all 0.2s; background: #fafafa; font-family: 'Tajawal', sans-serif;
        }
        .fg input:focus, .fg select:focus, .fg textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(255,179,71,0.12); background: white; }
        .fg.full { grid-column: span 2; }
        .fg textarea { resize: vertical; min-height: 80px; }

        /* ====== BUTTONS ====== */
        .btn-submit { background: linear-gradient(145deg, var(--green), var(--green-light)); color: white; padding: 0.75rem 1.8rem; border: none; border-radius: 30px; font-weight: 700; cursor: pointer; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; margin-top: 0.8rem; font-family: 'Tajawal', sans-serif; }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(30,90,58,0.3); }
        .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .btn-danger { background: linear-gradient(145deg, var(--red), var(--red-light)); color: white; padding: 0.75rem 1.8rem; border: none; border-radius: 30px; font-weight: 700; cursor: pointer; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; margin-top: 0.8rem; font-family: 'Tajawal', sans-serif; }
        .btn-danger:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(192,57,43,0.3); }
        .btn-danger:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .btn-secondary { background: white; color: var(--green); padding: 0.75rem 1.8rem; border: 2px solid var(--green); border-radius: 30px; font-weight: 700; cursor: pointer; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; margin-top: 0.8rem; font-family: 'Tajawal', sans-serif; }
        .btn-secondary:hover { background: var(--green-pale); }
        .btn-accent { background: linear-gradient(145deg, var(--accent-dark), var(--accent)); color: white; padding: 0.75rem 1.8rem; border: none; border-radius: 30px; font-weight: 700; cursor: pointer; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; margin-top: 0.8rem; font-family: 'Tajawal', sans-serif; }
        .btn-accent:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255,179,71,0.4); }
        .btn-row { display: flex; gap: 0.8rem; flex-wrap: wrap; align-items: center; }

        /* ====== MESSAGES ====== */
        .success-msg { color: #155724; background: #d4edda; padding: 0.8rem 1rem; border-radius: 10px; margin-top: 1rem; display: none; font-size: 0.9rem; border: 1px solid #c3e6cb; }
        .success-msg.show { display: block; }
        .err-msg { color: #721c24; background: #f8d7da; padding: 0.8rem 1rem; border-radius: 10px; margin-top: 1rem; display: none; font-size: 0.9rem; border: 1px solid #f5c6cb; }
        .err-msg.show { display: block; }
        .warn-box { color: #856404; background: #fff8d6; padding: 1rem 1.2rem; border-radius: 10px; margin-bottom: 1.2rem; font-size: 0.9rem; border: 1px solid #ffd54f; display: flex; align-items: flex-start; gap: 0.5rem; }
        .info-box { color: #0c5460; background: #d1ecf1; padding: 1rem 1.2rem; border-radius: 10px; margin-bottom: 1.2rem; font-size: 0.9rem; border: 1px solid #bee5eb; display: flex; align-items: flex-start; gap: 0.5rem; }

        /* ====== TABLE ====== */
        .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid rgba(30,90,58,0.1); max-height: 500px; overflow-y: auto; }
        .admin-data-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
        .admin-data-table th { background: linear-gradient(135deg, var(--green), var(--green-light)); color: white; padding: 0.8rem 1rem; text-align: right; font-size: 0.82rem; font-weight: 700; position: sticky; top: 0; }
        .admin-data-table td { padding: 0.65rem 1rem; border-bottom: 1px solid rgba(30,90,58,0.07); text-align: right; }
        .admin-data-table tr:nth-child(even) td { background: #f8fdf9; }
        .admin-data-table tr:hover td { background: rgba(255,179,71,0.07); }
        .search-bar { display: flex; align-items: center; gap: 0.5rem; background: #f8faf8; border: 1.5px solid rgba(30,90,58,0.15); border-radius: 10px; padding: 0.6rem 1rem; margin-bottom: 1rem; }
        .search-bar input { border: none; outline: none; font-size: 0.95rem; flex: 1; background: transparent; font-family: 'Tajawal', sans-serif; }
        .search-bar i { color: #aaa; }
        .count-badge { background: var(--green-pale); color: var(--green); padding: 0.4rem 1rem; border-radius: 30px; font-size: 0.85rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.4rem; }

        /* ====== GRADE BADGE ====== */
        .grade-pill { padding: 0.2rem 0.7rem; border-radius: 20px; font-weight: 700; font-size: 0.82rem; display: inline-block; }
        .grade-A { background: #d4edda; color: #155724; }
        .grade-B { background: #cce5ff; color: #004085; }
        .grade-C { background: #fff3cd; color: #856404; }
        .grade-D { background: #ffe5b4; color: #b45309; }
        .grade-F { background: #f8d7da; color: #721c24; }

        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .form-grid { grid-template-columns: 1fr; }
            .fg.full { grid-column: span 1; }
        }
        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .login-box { margin: 1rem; padding: 2rem 1.5rem; }
        }
    </style>
</head>
<body>

<!-- LOGIN BOX -->
<div class="login-box" id="loginBox">
    <div class="logo"><i class="fas fa-shield-alt"></i></div>
    <h1>بوابة الإدارة</h1>
    <p class="subtitle">معهد بتلند كنجا الإسلامي · للمشرفين فقط</p>
    <div class="form-group">
        <label>اسم المستخدم</label>
        <div class="input-wrap">
            <i class="fas fa-user"></i>
            <input type="text" id="admin-username" placeholder="أدخل اسم المستخدم" autocomplete="off">
        </div>
    </div>
    <div class="form-group">
        <label>كلمة المرور</label>
        <div class="input-wrap">
            <i class="fas fa-lock"></i>
            <input type="password" id="admin-password" placeholder="أدخل كلمة المرور">
        </div>
    </div>
    <button class="btn-login" id="loginBtn" onclick="doAdminLogin()">
        <i class="fas fa-sign-in-alt"></i> دخول لوحة الإدارة
    </button>
    <div class="error-msg" id="login-error"></div>
    <a href="/" class="back-link"><i class="fas fa-arrow-right"></i> العودة للموقع الرئيسي</a>
</div>

<!-- ADMIN DASHBOARD -->
<div class="dashboard-overlay" id="adminDashboard">
    <div class="dashboard-header">
        <h2><i class="fas fa-shield-alt"></i> لوحة الإدارة — معهد بتلند كنجا الإسلامي</h2>
        <div class="header-actions">
            <span id="header-time" style="color:rgba(255,255,255,0.7);font-size:0.85rem;"></span>
            <button class="dashboard-logout" onclick="doLogout()">
                <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
            </button>
        </div>
    </div>
    <div class="dashboard-body">

        <!-- STATS GRID -->
        <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-users"></i></div>
                <div class="stat-info"><div class="stat-number" id="stat-students">—</div><div class="stat-label">إجمالي الطلاب</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-clipboard-list"></i></div>
                <div class="stat-info"><div class="stat-number" id="stat-results">—</div><div class="stat-label">إجمالي النتائج</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-school"></i></div>
                <div class="stat-info"><div class="stat-number" id="stat-classes">18</div><div class="stat-label">عدد الفصول</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple"><i class="fas fa-book"></i></div>
                <div class="stat-info"><div class="stat-number" id="stat-subjects">—</div><div class="stat-label">المواد الدراسية</div></div>
            </div>
        </div>

        <!-- TABS -->
        <div class="tabs-container">
            <button class="admin-tab active" onclick="switchTab('dashboard',this)"><i class="fas fa-chart-pie"></i> الإحصائيات</button>
            <button class="admin-tab" onclick="switchTab('add-marks',this)"><i class="fas fa-edit"></i> إدخال النتائج</button>
            <button class="admin-tab" onclick="switchTab('add-student',this)"><i class="fas fa-user-plus"></i> إضافة طالب</button>
            <button class="admin-tab" onclick="switchTab('all-students',this)"><i class="fas fa-users"></i> كل الطلاب</button>
            <button class="admin-tab" onclick="switchTab('update-student',this)"><i class="fas fa-user-edit"></i> تعديل طالب</button>
            <button class="admin-tab" onclick="switchTab('delete-student',this)"><i class="fas fa-user-times"></i> حذف طالب</button>
            <button class="admin-tab" onclick="switchTab('all-results',this)"><i class="fas fa-table"></i> كل النتائج</button>
            <button class="admin-tab" onclick="switchTab('delete-results',this)"><i class="fas fa-trash-alt"></i> حذف نتائج</button>
            <button class="admin-tab" onclick="switchTab('reset-password',this)"><i class="fas fa-key"></i> إعادة كلمة المرور</button>
        </div>

        <!-- PANEL: DASHBOARD / STATS -->
        <div class="admin-panel active" id="panel-dashboard">
            <div class="admin-form-card">
                <h3><i class="fas fa-chart-bar"></i> إحصائيات النظام</h3>
                <div id="grade-breakdown" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:0.5rem;">
                    <div style="text-align:center;padding:1.2rem;background:var(--green-pale);border-radius:12px;">
                        <div style="font-size:2rem;font-weight:900;color:var(--green);" id="count-10">—</div>
                        <div style="font-size:0.85rem;color:#666;font-weight:600;">الصف العاشر</div>
                    </div>
                    <div style="text-align:center;padding:1.2rem;background:#fff8e8;border-radius:12px;">
                        <div style="font-size:2rem;font-weight:900;color:#e67e22;" id="count-11">—</div>
                        <div style="font-size:0.85rem;color:#666;font-weight:600;">الصف الحادي عشر</div>
                    </div>
                    <div style="text-align:center;padding:1.2rem;background:#e8f4fd;border-radius:12px;">
                        <div style="font-size:2rem;font-weight:900;color:#2471a3;" id="count-12">—</div>
                        <div style="font-size:0.85rem;color:#666;font-weight:600;">الصف الثاني عشر</div>
                    </div>
                </div>
                <button class="btn-submit" style="margin-top:1rem;font-size:0.85rem;padding:0.6rem 1.2rem;" onclick="loadDashboardStats()">
                    <i class="fas fa-sync-alt"></i> تحديث الإحصائيات
                </button>
            </div>
        </div>

        <!-- PANEL: ADD MARKS -->
        <div class="admin-panel" id="panel-add-marks">
            <div class="admin-form-card">
                <h3><i class="fas fa-edit"></i> إدخال نتائج الطالب</h3>
                <div class="form-grid">
                    <div class="fg"><label>الصف الدراسي *</label>
                        <select id="marks-grade-filter" onchange="filterStudentsByGradeClass()">
                            <option value="">-- اختر الصف --</option>
                            <option value="10">الصف العاشر</option>
                            <option value="11">الصف الحادي عشر</option>
                            <option value="12">الصف الثاني عشر</option>
                        </select>
                    </div>
                    <div class="fg"><label>الفصل *</label>
                        <select id="marks-class-filter" onchange="filterStudentsByGradeClass()">
                            <option value="">-- اختر الفصل --</option>
                            <option value="أ">الفصل أ</option><option value="ب">الفصل ب</option>
                            <option value="ج">الفصل ج</option><option value="د">الفصل د</option>
                            <option value="هـ">الفصل هـ</option><option value="و">الفصل و</option>
                        </select>
                    </div>
                    <div class="fg"><label>الطالب *</label>
                        <select id="marks-studentId"><option value="">-- اختر الصف والفصل أولاً --</option></select>
                    </div>
                    <div class="fg"><label>المادة *</label>
                        <select id="marks-subject">
                            <option value="">-- اختر المادة --</option>
                            <option value="القرآن الكريم">القرآن الكريم</option>
                            <option value="التفسير">التفسير</option>
                            <option value="الحديث">الحديث</option>
                            <option value="أصول الحديث">أصول الحديث</option>
                            <option value="التوحيد">التوحيد</option>
                            <option value="الفقه">الفقه</option>
                            <option value="الفرائض">الفرائض</option>
                            <option value="النحو">النحو</option>
                            <option value="البلاغة">البلاغة</option>
                            <option value="الأدب">الأدب</option>
                            <option value="المطالعة">المطالعة</option>
